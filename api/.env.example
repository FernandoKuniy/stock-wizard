FINNHUB_API_KEY=
DATABASE_URL=
# Your Supabase project URL, e.g. https://abcdefgh.supabase.co. Not a secret: the API
# uses it to find the project's public JWKS and verify users' access tokens locally.
# The project must have JWT signing keys enabled (asymmetric ES256/RS256, the default
# for new projects). The legacy shared HS256 secret is not accepted.
SUPABASE_URL=
# Optional. Twelve Data key for the historical price charts. Finnhub's free tier
# no longer serves candles; the app still runs without this, only charts need it.
TWELVE_DATA_API_KEY=
# Optional. Frontend origin allowed through CORS. Defaults to http://localhost:3000
# when unset, so leave it out unless you need to override it.
# FRONTEND_ORIGIN=
