# Base URL of the FastAPI backend the frontend talks to.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Your Supabase project, from its API settings. Both are public and safe to ship to the
# browser: the key only lets someone start an auth flow, it never reads data on its own.
# Use the publishable key (sb_publishable_...), never the secret key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
